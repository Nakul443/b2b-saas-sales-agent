# ==============================================================================
# Python Environment & Package Caches
# ==============================================================================
backend/venv/
backend/.venv/
backend/env/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# ==============================================================================
# Environment Secrets & Sensitive Credentials (CRITICAL)
# ==============================================================================
backend/.env
backend/.env.*
**/.env
**/secrets.json

# ==============================================================================
# SQLite Databases & Transaction Logs
# ==============================================================================
backend/*.db
backend/app/db/*.db
backend/app/db/database.db

# SQLite structural state tracking and rollback journals
**/*.db-journal
**/*.db-wal
**/*.db-shm

# ==============================================================================
# IDE & System Specific Exclusions
# ==============================================================================
.vscode/
.idea/
*.swp
*~
.DS_Store


# SQLite database files
*.sqlite
*.db
*.sqlite3

# Alembic specific environment files (if you store sensitive info there)
alembic.ini